<?xml version="1.0" encoding="utf-8"?><androidx.coordinatorlayout.widget.CoordinatorLayout    xmlns:android="http://schemas.android.com/apk/res/android"    xmlns:app="http://schemas.android.com/apk/res-auto"    xmlns:tools="http://schemas.android.com/tools"    android:layout_width="match_parent"    android:layout_height="match_parent"    android:background="#F5F5F5">    <!-- Map View — full screen, no children -->    <org.osmdroid.views.MapView        android:id="@+id/map"        android:layout_width="match_parent"        android:layout_height="match_parent"        android:contentDescription="@string/map_view" />    <!-- Bottom Sheet -->    <androidx.core.widget.NestedScrollView        android:id="@+id/bottom_sheet_scroll_view"        android:layout_width="match_parent"        android:layout_height="match_parent"        android:background="@android:color/white"        android:fillViewport="true"        android:clipToPadding="false"        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"        app:behavior_peekHeight="90dp"        app:behavior_hideable="false"        app:behavior_fitToContents="false"        app:behavior_halfExpandedRatio="0.5">        <androidx.constraintlayout.widget.ConstraintLayout            android:id="@+id/bottom_sheet_content"            android:layout_width="match_parent"            android:layout_height="wrap_content"            android:padding="20dp">            <!-- Drag Handle -->            <View                android:id="@+id/bottom_sheet_handle"                android:layout_width="40dp"                android:layout_height="6dp"                android:background="#DDDDDD"                app:layout_constraintStart_toStartOf="parent"                app:layout_constraintEnd_toEndOf="parent"                app:layout_constraintTop_toTopOf="parent" />            <!-- Title -->            <TextView                android:id="@+id/tv_title"                android:layout_width="0dp"                android:layout_height="wrap_content"                android:layout_marginTop="16dp"                android:text="@string/safety_route_planner"                android:textColor="#222222"                android:textSize="20sp"                android:textStyle="bold"                app:layout_constraintEnd_toStartOf="@id/btn_plan_route"                app:layout_constraintStart_toStartOf="parent"                app:layout_constraintTop_toBottomOf="@id/bottom_sheet_handle" />            <!-- Plan Route Button -->            <com.google.android.material.button.MaterialButton                android:id="@+id/btn_plan_route"                android:layout_width="wrap_content"                android:layout_height="wrap_content"                android:text="@string/go"                app:cornerRadius="20dp"                app:layout_constraintEnd_toEndOf="parent"                app:layout_constraintTop_toTopOf="@id/tv_title" />            <!-- Safety Description -->            <TextView                android:id="@+id/tv_safety_description"                android:layout_width="0dp"                android:layout_height="wrap_content"                android:text="Ready to route"                android:textColor="#666666"                android:textSize="14sp"                app:layout_constraintEnd_toStartOf="@id/btn_plan_route"                app:layout_constraintStart_toStartOf="parent"                app:layout_constraintTop_toBottomOf="@id/tv_title" />            <!-- Overall Safety Progress Bar -->            <ProgressBar                android:id="@+id/pb_overall_safety"                style="?android:attr/progressBarStyleHorizontal"                android:layout_width="0dp"                android:layout_height="12dp"                android:layout_marginTop="16dp"                android:max="100"                android:progress="0"                app:layout_constraintEnd_toEndOf="parent"                app:layout_constraintStart_toStartOf="parent"                app:layout_constraintTop_toBottomOf="@id/tv_safety_description" />            <!-- ✅ FIX: Safety Warnings anchored to pb_overall_safety -->            <com.google.android.material.card.MaterialCardView                android:id="@+id/layout_safety_warnings"                android:layout_width="0dp"                android:layout_height="wrap_content"                android:layout_marginTop="16dp"                android:visibility="gone"                app:cardBackgroundColor="#FFF3F3"                app:cardCornerRadius="12dp"                app:cardElevation="0dp"                app:strokeColor="#FFCDD2"                app:strokeWidth="1dp"                app:layout_constraintEnd_toEndOf="parent"                app:layout_constraintStart_toStartOf="parent"                app:layout_constraintTop_toBottomOf="@id/pb_overall_safety"                tools:visibility="visible">                <LinearLayout                    android:layout_width="match_parent"                    android:layout_height="wrap_content"                    android:orientation="vertical"                    android:padding="12dp">                    <LinearLayout                        android:layout_width="match_parent"                        android:layout_height="wrap_content"                        android:gravity="center_vertical"                        android:orientation="horizontal">                        <ImageView                            android:layout_width="20dp"                            android:layout_height="20dp"                            android:src="@android:drawable/stat_sys_warning"                            app:tint="#D32F2F" />                        <TextView                            android:layout_width="wrap_content"                            android:layout_height="wrap_content"                            android:layout_marginStart="8dp"                            android:text="Safety Alerts"                            android:textColor="#D32F2F"                            android:textSize="14sp"                            android:textStyle="bold" />                    </LinearLayout>                    <TextView                        android:id="@+id/tv_safety_warnings_list"                        android:layout_width="match_parent"                        android:layout_height="wrap_content"                        android:layout_marginTop="8dp"                        android:lineSpacingExtra="2dp"                        android:text="• High incident zone ahead."                        android:textColor="#B71C1C"                        android:textSize="13sp" />                </LinearLayout>            </com.google.android.material.card.MaterialCardView>            <!-- ✅ FIX: Route Info Card anchored BELOW layout_safety_warnings -->            <LinearLayout                android:id="@+id/route_info_container"                android:layout_width="0dp"                android:layout_height="wrap_content"                android:layout_marginTop="16dp"                android:background="#F5F5F5"                android:orientation="horizontal"                android:padding="12dp"                android:visibility="gone"                app:layout_constraintEnd_toEndOf="parent"                app:layout_constraintStart_toStartOf="parent"                app:layout_constraintTop_toBottomOf="@id/layout_safety_warnings"                tools:visibility="visible">                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">                    <TextView android:id="@+id/tv_route_distance" android:layout_width="wrap_content"                        android:layout_height="wrap_content" android:text="-- km"                        android:textColor="#222222" android:textSize="16sp" android:textStyle="bold" />                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"                        android:text="Distance" android:textColor="#666666" android:textSize="12sp" />                </LinearLayout>                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">                    <TextView android:id="@+id/tv_route_duration" android:layout_width="wrap_content"                        android:layout_height="wrap_content" android:text="-- min"                        android:textColor="#222222" android:textSize="16sp" android:textStyle="bold" />                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"                        android:text="Duration" android:textColor="#666666" android:textSize="12sp" />                </LinearLayout>                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">                    <TextView android:id="@+id/tv_transport_mode" android:layout_width="wrap_content"                        android:layout_height="wrap_content" android:text="--"                        android:textColor="#222222" android:textSize="16sp" android:textStyle="bold" />                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"                        android:text="Mode" android:textColor="#666666" android:textSize="12sp" />                </LinearLayout>            </LinearLayout>            <!-- Alternative Routes Switch -->            <com.google.android.material.switchmaterial.SwitchMaterial                android:id="@+id/switch_alternative_routes"                android:layout_width="0dp"                android:layout_height="wrap_content"                android:layout_marginTop="16dp"                android:checked="false"                android:text="Show Alternative Routes"                android:textSize="14sp"                app:layout_constraintEnd_toEndOf="parent"                app:layout_constraintStart_toStartOf="parent"                app:layout_constraintTop_toBottomOf="@id/route_info_container" />            <!-- Route Filter Buttons -->            <LinearLayout                android:id="@+id/route_filter_buttons"                android:layout_width="0dp"                android:layout_height="wrap_content"                android:layout_marginTop="12dp"                android:orientation="horizontal"                app:layout_constraintEnd_toEndOf="parent"                app:layout_constraintStart_toStartOf="parent"                app:layout_constraintTop_toBottomOf="@id/switch_alternative_routes">                <Button android:id="@+id/btnFastest" android:layout_width="0dp"                    android:layout_height="wrap_content" android:layout_weight="1"                    app:backgroundTint="#698BEB" android:text="Fastest" />                <Button android:id="@+id/btnSafest" android:layout_width="0dp"                    android:layout_height="wrap_content" android:layout_marginStart="8dp"                    android:layout_weight="1" app:backgroundTint="#417144" android:text="Safest" />                <Button android:id="@+id/btnRisk" android:layout_width="0dp"                    android:layout_height="wrap_content" android:layout_marginStart="8dp"                    android:layout_weight="1" app:backgroundTint="#E66767" android:text="High Risk" />            </LinearLayout>            <!-- ✅ FIX: btn_toggle_safe_zones anchored below route_filter_buttons -->            <com.google.android.material.button.MaterialButton                android:id="@+id/btn_toggle_safe_zones"                android:layout_width="0dp"                android:layout_height="wrap_content"                android:layout_marginTop="10dp"                android:text="Show Safe Zones"                android:visibility="gone"                app:layout_constraintTop_toBottomOf="@id/route_filter_buttons"                app:layout_constraintStart_toStartOf="parent"                app:layout_constraintEnd_toEndOf="parent" />            <!-- ✅ FIX: btn_manage_sos anchored below btn_toggle_safe_zones -->            <com.google.android.material.button.MaterialButton                android:id="@+id/btn_manage_sos"                android:layout_width="0dp"                android:layout_height="wrap_content"                android:layout_marginTop="10dp"                android:text="@string/manage_sos_contacts"                android:textAllCaps="false"                app:cornerRadius="12dp"                app:icon="@android:drawable/ic_menu_call"                app:backgroundTint="#9054F6"                app:layout_constraintTop_toBottomOf="@id/btn_toggle_safe_zones"                app:layout_constraintStart_toStartOf="parent"                app:layout_constraintEnd_toEndOf="parent" />            <com.google.android.material.button.MaterialButton                android:id="@+id/btn_report_incident"                android:layout_width="0dp"                android:layout_height="wrap_content"                android:layout_marginTop="10dp"                android:layout_marginEnd="4dp"                android:text="Report"                android:textAllCaps="false"                app:cornerRadius="12dp"                app:icon="@android:drawable/ic_menu_report_image"                app:backgroundTint="#FF9800"                app:layout_constraintTop_toBottomOf="@id/btn_manage_sos"                app:layout_constraintStart_toStartOf="parent"                app:layout_constraintEnd_toStartOf="@+id/btn_view_incidents"                app:layout_constraintHorizontal_chainStyle="spread" />            <com.google.android.material.button.MaterialButton                android:id="@+id/btn_view_incidents"                android:layout_width="0dp"                android:layout_height="wrap_content"                android:layout_marginTop="10dp"                android:layout_marginStart="4dp"                android:text="View Reports"                android:textAllCaps="false"                app:cornerRadius="12dp"                app:icon="@android:drawable/ic_menu_view"                app:backgroundTint="#4CAF50"                app:layout_constraintTop_toBottomOf="@id/btn_manage_sos"                app:layout_constraintStart_toEndOf="@id/btn_report_incident"                app:layout_constraintEnd_toEndOf="parent" />            <!-- ✅ FIX: tvAiRiskScore anchored below btn_manage_sos -->            <TextView                android:id="@+id/tvAiRiskScore"                android:layout_width="0dp"                android:layout_height="wrap_content"                android:layout_marginTop="24dp"                android:gravity="center_horizontal"                android:text="AI Model: Idle"                android:textColor="#888888"                android:textSize="12sp"                app:layout_constraintEnd_toEndOf="parent"                app:layout_constraintStart_toStartOf="parent"                app:layout_constraintTop_toBottomOf="@id/btn_report_incident" />            <!-- Detailed Analysis Header -->            <TextView                android:id="@+id/tv_analysis_header"                android:layout_width="wrap_content"                android:layout_height="wrap_content"                android:layout_marginTop="16dp"                android:text="Detailed Analysis"                android:textSize="16sp"                android:textStyle="bold"                app:layout_constraintStart_toStartOf="parent"                app:layout_constraintTop_toBottomOf="@id/tvAiRiskScore" />            <!-- Analysis Items Container -->            <LinearLayout                android:id="@+id/analysis_container"                android:layout_width="0dp"                android:layout_height="wrap_content"                android:layout_marginTop="12dp"                android:orientation="vertical"                app:layout_constraintEnd_toEndOf="parent"                app:layout_constraintStart_toStartOf="parent"                app:layout_constraintTop_toBottomOf="@id/tv_analysis_header">                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"                    android:gravity="center_vertical" android:orientation="horizontal" android:paddingVertical="8dp">                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"                        android:layout_weight="1" android:text="Crime Risk" android:textStyle="bold" />                    <TextView android:id="@+id/tvCrimeScore" android:layout_width="wrap_content"                        android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:text="--" />                    <TextView android:id="@+id/chip_crime" android:layout_width="wrap_content"                        android:layout_height="wrap_content" android:background="#EEEEEE"                        android:paddingStart="8dp" android:paddingTop="4dp" android:paddingEnd="8dp"                        android:paddingBottom="4dp" android:text="--" android:textSize="12sp" />                </LinearLayout>                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"                    android:gravity="center_vertical" android:orientation="horizontal" android:paddingVertical="8dp">                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"                        android:layout_weight="1" android:text="Lighting" android:textStyle="bold" />                    <TextView android:id="@+id/tvLighting" android:layout_width="wrap_content"                        android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:text="--" />                    <TextView android:id="@+id/chip_lighting" android:layout_width="wrap_content"                        android:layout_height="wrap_content" android:background="#EEEEEE"                        android:paddingStart="8dp" android:paddingTop="4dp" android:paddingEnd="8dp"                        android:paddingBottom="4dp" android:text="--" android:textSize="12sp" />                </LinearLayout>                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"                    android:gravity="center_vertical" android:orientation="horizontal" android:paddingVertical="8dp">                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"                        android:layout_weight="1" android:text="Crowd Density" android:textStyle="bold" />                    <TextView android:id="@+id/tvCrowdDensity" android:layout_width="wrap_content"                        android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:text="--" />                    <TextView android:id="@+id/chip_crowd" android:layout_width="wrap_content"                        android:layout_height="wrap_content" android:background="#EEEEEE"                        android:paddingStart="8dp" android:paddingTop="4dp" android:paddingEnd="8dp"                        android:paddingBottom="4dp" android:text="--" android:textSize="12sp" />                </LinearLayout>                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"                    android:gravity="center_vertical" android:orientation="horizontal" android:paddingVertical="8dp">                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"                        android:layout_weight="1" android:text="Road Quality" android:textStyle="bold" />                    <TextView android:id="@+id/tvRoadQuality" android:layout_width="wrap_content"                        android:layout_height="wrap_content" android:text="--" />                </LinearLayout>                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"                    android:gravity="center_vertical" android:orientation="horizontal" android:paddingVertical="8dp">                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"                        android:layout_weight="1" android:text="Past Accidents" android:textStyle="bold" />                    <TextView android:id="@+id/tvAccidents" android:layout_width="wrap_content"                        android:layout_height="wrap_content" android:text="No data" />                </LinearLayout>                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"                    android:orientation="horizontal" android:paddingVertical="8dp">                    <TextView android:id="@+id/tvPoliceDist" android:layout_width="0dp"                        android:layout_height="wrap_content" android:layout_weight="1"                        android:text="Police: ~0 km" android:textSize="12sp" />                    <TextView android:id="@+id/tvNightSafety" android:layout_width="wrap_content"                        android:layout_height="wrap_content" android:text="Night: Not Safe" android:textSize="12sp" />                </LinearLayout>            </LinearLayout>            <!-- ═══════════════════════════════════════════════ -->            <!-- Recent Safety News Section                      -->            <!-- ═══════════════════════════════════════════════ -->            <!-- News Header Row: title + reload button -->            <TextView                android:id="@+id/tv_news_header"                android:layout_width="0dp"                android:layout_height="wrap_content"                android:layout_marginTop="24dp"                android:text="Recent Safety News"                android:textSize="16sp"                android:textStyle="bold"                app:layout_constraintEnd_toStartOf="@id/btn_refresh_crime"                app:layout_constraintStart_toStartOf="parent"                app:layout_constraintTop_toBottomOf="@id/analysis_container" />            <com.google.android.material.button.MaterialButton                android:id="@+id/btn_refresh_crime"                style="@style/Widget.MaterialComponents.Button.TextButton"                android:layout_width="wrap_content"                android:layout_height="wrap_content"                android:text="Reload"                app:layout_constraintBottom_toBottomOf="@id/tv_news_header"                app:layout_constraintEnd_toEndOf="parent"                app:layout_constraintTop_toTopOf="@id/tv_news_header" />            <!-- Destination News Toggle -->            <LinearLayout                android:id="@+id/news_toggle_row"                android:layout_width="0dp"                android:layout_height="wrap_content"                android:layout_marginTop="10dp"                android:background="#F0F4FF"                android:orientation="horizontal"                android:gravity="center_vertical"                android:paddingStart="12dp"                android:paddingEnd="12dp"                android:paddingTop="8dp"                android:paddingBottom="8dp"                app:layout_constraintEnd_toEndOf="parent"                app:layout_constraintStart_toStartOf="parent"                app:layout_constraintTop_toBottomOf="@id/tv_news_header">                <LinearLayout                    android:layout_width="0dp"                    android:layout_height="wrap_content"                    android:layout_weight="1"                    android:orientation="vertical">                    <TextView                        android:layout_width="wrap_content"                        android:layout_height="wrap_content"                        android:text="Destination Area News"                        android:textColor="#222222"                        android:textSize="13sp"                        android:textStyle="bold" />                    <TextView                        android:id="@+id/tv_news_location_label"                        android:layout_width="wrap_content"                        android:layout_height="wrap_content"                        android:text="Set a destination to enable"                        android:textColor="#888888"                        android:textSize="11sp" />                </LinearLayout>                <com.google.android.material.switchmaterial.SwitchMaterial                    android:id="@+id/switch_destination_news"                    android:layout_width="wrap_content"                    android:layout_height="wrap_content"                    android:checked="false"                    android:enabled="false" />            </LinearLayout>            <!-- News progress bar -->            <ProgressBar                android:id="@+id/news_progress_bar"                android:layout_width="30dp"                android:layout_height="30dp"                android:layout_marginTop="12dp"                android:visibility="gone"                app:layout_constraintEnd_toEndOf="parent"                app:layout_constraintStart_toStartOf="parent"                app:layout_constraintTop_toBottomOf="@id/news_toggle_row"                tools:visibility="visible" />            <!-- News items container -->            <LinearLayout                android:id="@+id/news_container"                android:layout_width="0dp"                android:layout_height="wrap_content"                android:layout_marginTop="12dp"                android:orientation="vertical"                app:layout_constraintEnd_toEndOf="parent"                app:layout_constraintStart_toStartOf="parent"                app:layout_constraintTop_toBottomOf="@id/news_progress_bar" />            <!-- Bottom Spacing -->            <Space                android:layout_width="match_parent"                android:layout_height="60dp"                app:layout_constraintTop_toBottomOf="@id/news_container" />        </androidx.constraintlayout.widget.ConstraintLayout>    </androidx.core.widget.NestedScrollView>    <!-- Search Bar -->    <com.google.android.material.card.MaterialCardView        android:layout_width="match_parent"        android:layout_height="wrap_content"        android:layout_margin="16dp"        app:cardElevation="6dp"        app:cardCornerRadius="28dp"        app:cardBackgroundColor="@android:color/white">        <LinearLayout            android:layout_width="match_parent"            android:layout_height="wrap_content"            android:orientation="horizontal"            android:gravity="center_vertical"            android:paddingStart="16dp"            android:paddingEnd="8dp"            android:paddingTop="8dp"            android:paddingBottom="8dp">            <EditText                android:id="@+id/input_destination"                android:layout_width="0dp"                android:layout_height="48dp"                android:layout_weight="1"                android:background="@android:color/transparent"                android:textColor="#212121"                android:textColorHint="#9E9E9E"                android:hint="Search destination..."                android:imeOptions="actionSearch"                android:inputType="text"                android:padding="12dp"                android:textSize="16sp"                android:importantForAutofill="no"                tools:ignore="LabelFor"/>            <ImageButton                android:id="@+id/btn_my_location"                android:layout_width="48dp"                android:layout_height="48dp"                android:padding="12dp"                android:background="?attr/selectableItemBackgroundBorderless"                android:contentDescription="My Location"                android:src="@drawable/ic_my_location"                app:tint="#424242"                tools:tint="#424242" />        </LinearLayout>    </com.google.android.material.card.MaterialCardView>    <!-- Search FAB -->    <com.google.android.material.floatingactionbutton.FloatingActionButton        android:id="@+id/fab_search_trigger"        android:layout_width="wrap_content"        android:layout_height="wrap_content"        android:layout_gravity="end|bottom"        android:layout_marginEnd="16dp"        android:layout_marginBottom="300dp"        android:contentDescription="Search"        app:fabSize="normal"        app:backgroundTint="@android:color/white"        app:tint="@android:color/black"        app:srcCompat="@drawable/ic_search"/>    <!-- SOS FAB -->    <com.google.android.material.floatingactionbutton.FloatingActionButton        android:id="@+id/fab_sos"        android:layout_width="wrap_content"        android:layout_height="wrap_content"        android:layout_gravity="end|bottom"        android:layout_marginEnd="16dp"        android:layout_marginBottom="220dp"        android:contentDescription="SOS"        android:elevation="8dp"        app:fabSize="normal"        app:backgroundTint="#D32F2F"        app:tint="@android:color/white"        app:srcCompat="@drawable/ic_sos"/></androidx.coordinatorlayout.widget.CoordinatorLayout>